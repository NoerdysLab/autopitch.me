# Copy to .env.local and fill in. .env.local is gitignored.

# Neon Postgres connection string. Get from neon.tech → your project →
# "Connection string". Looks like:
#   postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# 32+ random bytes that encrypts the session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=

# Resend API key (re_...). Get from resend.com → API Keys.
# If unset in development, sign-in codes are logged to the server console
# instead of being emailed — handy before Resend is wired up.
RESEND_API_KEY=

# From-address for outbound mail. Until you verify a domain in Resend, leave
# this on the default test sender — Resend will only deliver to the email
# you signed up with.
RESEND_FROM="autopitch <onboarding@resend.dev>"
